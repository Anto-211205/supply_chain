{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://supply-chain-api.onrender.com/api/$1"
    }
  ],
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  }
}
